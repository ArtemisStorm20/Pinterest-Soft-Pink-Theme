{
    "manifest_version": 3,
    "name": "Pinterest Soft Pink Theme",
    "version": "1.0",
    "description": "A soft pink theme for Pinterest.",
    "permissions": [
        "activeTab"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16" : "image-removebg-preview.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["*://www.pinterest.com/*"],
            "css": ["Css/theme.css"],
            "js": ["content.js"]
        }
    ]
}